cdecl fn printf(fmt: str, ...) i32;
cdecl fn exit(code: i32) void;

class Vector<T> {
    var data: T*;
    var size: i32; 
    var capacity: i32;

    constructor(self: Vector<T>*) {
        self.data = new T[1];
        self.size = 0;
        self.capacity = 1;
    }

    constructor(self: Vector<T>*, initial_cap: i32) {
        self.data = new T[initial_cap];
        self.size = 0;
        self.capacity = initial_cap;
    }

    fn push(self: Vector<T>*, item: T) {
        if (self.size >= self.capacity) {
            var new_capacity: i32 = self.capacity * 2;
            var new_data: T* = new T[new_capacity];
            for (var i = 0; i < self.size; ++i) {
                new_data[i] = self.data[i];
            }
            free self.data;
            self.data = new_data;
            self.capacity = new_capacity;
        }
        self.data[self.size] = item;
        self.size = self.size + 1;
    }

    fn pop(self: Vector<T>*) T {
        if (self.size == 0) {
            printf("ERROR: Cannot pop from an empty vector\n");
            exit(1);
        }

        self.size = self.size - 1;
        return self.data[self.size];
    }

    fn back(self: Vector<T>*) T {
        if (self.size == 0) {
            printf("ERROR: Vector is empty\n");
            exit(1);
        }
        return self.data[self.size - 1];
    }

    fn empty(self: Vector<T>*) bool {
        return self.size == 0;
    }

    fn get(self: Vector<T>*, index: i32) T {
        if (index < 0 || index >= self.size) {
            printf("ERROR: Index out of bounds\n");
            exit(1);
        }
        return self.data[index];
    }

    fn swap(self: Vector<T>*, i: i32, j: i32) {
        if (i < 0 || i >= self.size || j < 0 || j >= self.size) {
            printf("ERROR: Index out of bounds\n");
            exit(1);
        }
        var temp: T = self.data[i];
        self.data[i] = self.data[j];
        self.data[j] = temp;
    }
}