// NAME BasicGenericClass
// ERR 0
// RET 42

class Box<T> {
    var value: T;

    constructor(self: Box<T>*, val: T) {
        self.value = val;
    }

    fn getValue(self: Box<T>*) T {
        return self.value;
    }
}

fn main() i32 {
    var intBox: Box<i32>* = new Box<i32>(42);
    return intBox.getValue();
}

// NAME GenericClassMultipleInstances
// ERR 0
// RET 100

class Wrapper<T> {
    var item: T;
    constructor(self: Wrapper<T>*, item: T) {
        self.item = item;
    }
    fn get(self: Wrapper<T>*) T {
        return self.item;
    }
}

fn main() i32 {
    var x: Wrapper<i32>* = new Wrapper<i32>(100);
    var y: Wrapper<str>* = new Wrapper<str>("hello");
    return x.get();
}

// NAME GenericClassMultiMethod
// ERR 0
// RET 20

class Calc<T> {
    var v: T;
    constructor(self: Calc<T>*, v: T) {
        self.v = v;
    }
    fn update(self: Calc<T>*, v: T) {
        self.v = v;
    }
    fn get(self: Calc<T>*) T {
        return self.v;
    }
}

fn main() i32 {
    var c: Calc<i32>* = new Calc<i32>(10);
    c.update(20);
    return c.get();
}

// NAME GenericAsArgument
// ERR 0
// RET 5

class Container<T> {
    var item: T;
    constructor(self: Container<T>*, item: T) {
        self.item = item;
    }
}

fn extract(c: Container<i32>*) i32 {
    return c.item;
}

fn main() i32 {
    var c: Container<i32>* = new Container<i32>(5);
    return extract(c);
}

// NAME GenericVectorOfStrings
// ERR 0
// RET 3

class Vector<T> {
    var data: T*;
    var size: i32;
    var capacity: i32;

    constructor(self: Vector<T>*, initial_cap: i32) {
        self.data = new T[initial_cap];
        self.size = 0;
        self.capacity = initial_cap;
    }

    fn push(self: Vector<T>*, item: T) {
        if (self.size >= self.capacity) {
            var new_capacity: i32 = self.capacity * 2;
            var new_data: T* = new T[new_capacity];
            for (var i = 0; i < self.size; ++i) {
                new_data[i] = self.data[i];
            }
            free self.data;
            self.data = new_data;
            self.capacity = new_capacity;
        }

        self.data[self.size] = item;
        self.size = self.size + 1;
    }

    fn get(self: Vector<T>*, index: i32) T {
        return self.data[index];
    }
}

fn main() i32 {
    var vec: Vector<str>* = new Vector<str>(2);
    vec.push("hello");
    vec.push("world");
    vec.push("!");
    return vec.size;
}

// NAME GenericMethodCallOnMemberAccess
// ERR 0
// RET 0

class Vector<T> {
    var data: T*;
    var size: i32;
    var capacity: i32;

    constructor(self: Vector<T>*, initial_cap: i32) {
        self.data = new T[initial_cap];
        self.size = 0;
        self.capacity = initial_cap;
    }

    fn length(self: Vector<T>*) i32 {
        return self.size;
    }
}

typealias Vector<i32> IntList;

class Holder {
    var list: IntList*;

    constructor(self: Holder*) {
        self.list = new IntList(4);
    }
}

fn main() i32 {
    var holder: Holder* = new Holder();
    return holder.list.length();
}
